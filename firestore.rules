rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper function to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper function to check if user is accessing their own document
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // User profile rules
    match /users/{userId} {
      // Any authenticated user can read a profile (essential for finding recipients via UID)
      allow read: if isAuthenticated();
      
      // Only the owner can update their basic profile info
      allow update: if isOwner(userId) 
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['username', 'phone', 'email', 'updatedAt', 'walletBalance']);

      // Subcollections belonging to the user
      match /{allSubcollections=**} {
        // Only the owner can read/write their own subcollections (cards, bankAccounts, transactions, friends)
        // EXCEPT for the wallet subcollection which needs P2P access
        allow read, write: if isOwner(userId);
      }
      
      // Specific rules for the wallet subcollection to support P2P transfers
      match /wallet/{walletId} {
        // Any authenticated user can read/write to a wallet document
        // This is required for P2P transfers (sender deducts, receiver gains)
        // In a production app, you'd use Cloud Functions to make this more secure.
        allow read, write: if isAuthenticated();
      }
    }

    // Transactions collection (root level)
    match /transactions/{txnId} {
      // Allow read if the user is the sender or receiver
      allow read: if isAuthenticated() && 
                  (request.auth.uid == resource.data.senderUid || 
                   request.auth.uid == resource.data.receiverUid);
      
      // Allow create if the user is the sender
      allow create: if isAuthenticated() && request.auth.uid == request.resource.data.senderUid;
    }
  }
}
